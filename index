        <div class="flex flex-col md:flex-row gap-4 mb-8 sticky top-0 lg:static z-20 bg-[#022c22]/95 lg:bg-transparent p-3 lg:p-0 rounded-xl lg:rounded-none border border-[#14532d] lg:border-none shadow-lg lg:shadow-none backdrop-blur-md">
            <div class="relative flex-1">
                <i class="fas fa-search absolute left-4 top-4 text-green-500/60"></i>
                <input type="text" id="runeSearch" placeholder="Search for runes in the garden..." class="w-full bg-[#011c15]/80 border-2 border-green-900/50 text-white rounded-xl py-3.5 pl-12 pr-4 focus:border-green-500 focus:bg-black transition-all outline-none font-medium shadow-inner">
