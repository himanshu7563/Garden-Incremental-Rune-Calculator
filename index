        <!-- RNG Disclaimer Banner -->
        <div class="mt-4 mb-10 w-full shrink-0 bg-[#011c15] border-2 border-[#14532d] rounded-xl p-4 sm:p-5 flex flex-col sm:flex-row items-center sm:items-start gap-4 sm:gap-6 shadow-[0_8px_30px_rgba(0,0,0,0.5)] relative overflow-hidden">
            <div class="absolute inset-0 bg-gradient-to-r from-green-900/20 to-transparent pointer-events-none"></div>
            
            <div class="bg-green-950 p-3 sm:p-4 rounded-xl shrink-0 border border-green-800 relative z-10 flex items-center justify-center shadow-[inset_0_0_15px_rgba(74,222,128,0.1)]">
                <i class="fas fa-dice-d20 text-green-400 text-2xl sm:text-3xl opacity-90" style="filter: drop-shadow(0 0 10px rgba(74, 222, 128, 0.5));"></i>
            </div>
            
            <div class="relative z-10 flex-1 text-center sm:text-left">
