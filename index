        window.togglePin = function(name, e) {
            e.stopPropagation(); 
            if (window.pinnedRunes.has(name)) {
                window.pinnedRunes.delete(name);
            } else {
                window.pinnedRunes.add(name);
            }
            window.calculate(); 
        };

        window.calculate = function() {
            const speedEl = document.getElementById('speed');
            const bulkEl = document.getElementById('bulk');
            const luckEl = document.getElementById('luck');
            const targetEl = document.getElementById('target');
            
            if(!speedEl || !bulkEl || !luckEl || !targetEl) return;

            let speedInput = parseFloat(speedEl.value);
            let bulk = parseValue(bulkEl.value);
            let luck = parseValue(luckEl.value);
            const target = parseValue(targetEl.value);

            const speed2x = document.getElementById('speed2x')?.checked;
            const luck2x = document.getElementById('luck2x')?.checked;
            const bhSpeed = document.getElementById('bhSpeed')?.checked;
            const bhLuck = document.getElementById('bhLuck')?.checked;

            if (speed2x) bulk *= 2;
            if (bhSpeed) bulk *= 2; 
            
            let finalLuck = luck;
            if (luck2x) finalLuck *= 2;
            if (bhLuck) finalLuck *= 10;

            const effectiveRPS = bulk / (speedInput || 0.15);
            const effRPS = document.getElementById('effectiveRPS');
            if(effRPS) effRPS.innerText = formatValue(effectiveRPS);

            const totalPower = effectiveRPS * finalLuck;

            const etaElement = document.getElementById('customEta');
            const customPercentInput = document.getElementById('customPercent').value;
            const customPercentVal = customPercentInput !== '' ? parseFloat(customPercentInput) : NaN;

            if(etaElement){
                if (totalPower > 0 && target > 0) {
                    let sec = target / totalPower;
                    
                    if (!isNaN(customPercentVal) && customPercentVal > 0 && customPercentVal < 100) {
                        const probabilityMultiplier = -Math.log(1 - (customPercentVal / 100));
                        sec = sec * probabilityMultiplier;
                    }

                    etaElement.innerText = formatTime(sec);
                    if (sec >= 3600) { etaElement.className = "text-xl font-bold text-red-500 font-mono drop-shadow-md"; }
                    else if (sec >= 300) { etaElement.className = "text-xl font-bold text-orange-400 font-mono drop-shadow-md"; }
                    else { etaElement.className = "text-xl font-bold text-green-400 font-mono drop-shadow-md"; }
                } else { 
                    etaElement.innerText = "--"; 
                    etaElement.className = "text-xl font-bold text-green-500 font-mono drop-shadow-md";
                }
            }
            renderRunes(totalPower);
        };

        window.setModeCategory = function() {
            window.sortConfig.mode = 'category';
            updateSortUI();
            window.calculate();
        };

        window.setModeEta = function() {
            if (window.sortConfig.mode === 'eta') {
                window.sortConfig.direction = window.sortConfig.direction === 'asc' ? 'desc' : 'asc';
            } else {
                window.sortConfig.mode = 'eta';
                window.sortConfig.direction = 'asc';
            }
            updateSortUI();
