                card.innerHTML = `
                    <div class="p-4 relative z-10 flex-1">
                        <button class="absolute -top-2 -right-2 p-2 z-20 hover:scale-110 transition-transform" onclick="window.togglePin('${rune.name.replace(/'/g, "\\'")}', event)" title="Pin Rune">
                            <i class="fas fa-star text-xl drop-shadow-md ${isPinned ? 'text-yellow-400 drop-shadow-[0_0_10px_rgba(250,204,21,0.8)]' : 'text-white/20 hover:text-yellow-400/80'}"></i>
                        </button>

                        <div class="text-[9px] font-bold uppercase tracking-widest mb-1.5 flex items-center gap-1.5 relative z-10" style="color: ${borderColor}; text-shadow: 0 0 10px rgba(${catRgb},0.8)">
                            <i class="fas ${iconClass}"></i> ${rune.type}
                        </div>
                        
                        <h3 class="text-xl sm:text-2xl font-mystic text-white tracking-wide truncate mb-3 pr-6 relative z-10" style="${isSpecial ? `text-shadow: 0 0 15px rgba(${catRgb}, 1), 0 0 30px rgba(${catRgb}, 0.8);` : 'filter: drop-shadow(0 2px 4px rgba(0,0,0,0.8));'}">${rune.name}</h3>
                        
                        <div class="bg-black/40 rounded-lg p-3 border border-white/10 space-y-2 backdrop-blur-sm shadow-inner relative z-10" ${isSpecial ? `style="box-shadow: inset 0 0 15px rgba(${catRgb}, 0.2); border-color: rgba(${catRgb}, 0.3);"` : ''}>
                            <div class="flex justify-between text-[11px] font-bold">
                                <span class="text-green-300/60 uppercase tracking-wider">Chance:</span>
                                <span class="text-white font-mono">1 in ${chanceText}</span>
                            </div>
                            <div class="flex justify-between text-[11px] font-bold" title="Original Base ETA (63.2% Chance)">
                                <span class="text-green-300/60 uppercase tracking-wider">ETA (63% Base):</span>
                                <span class="${colorClass} font-mono">${eta}</span>
                            </div>
                            
                            <div class="border-t border-white/10 pt-2 mt-2 space-y-1.5">
                                <div class="flex justify-between text-[9px] sm:text-[10px] font-bold text-gray-400">
                                    <span class="uppercase tracking-wider">50% (Coin Flip):</span>
                                    <span class="font-mono text-gray-300">${eta50}</span>
                                </div>
                                <div class="flex justify-between text-[9px] sm:text-[10px] font-bold text-green-500/80">
                                    <span class="uppercase tracking-wider">75% (Very Likely):</span>
                                    <span class="font-mono text-green-400">${eta75}</span>
                                </div>
                                <div class="flex justify-between text-[9px] sm:text-[10px] font-bold text-purple-400/80">
                                    <span class="uppercase tracking-wider">99% (Guaranteed):</span>
                                    <span class="font-mono text-purple-400">${eta99}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="p-3 bg-black/50 border-t border-white/5 relative z-10 flex flex-wrap gap-1.5">
                        ${rune.stats.map(s => `<span class="stat-badge">${s}</span>`).join('')}
                    </div>
                    
                    <i class="fas ${iconClass} card-bg-icon"></i>
                `;
                grid.appendChild(card);
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const toggleBtn = document.getElementById('toggleConfig');
            const configContent = document.getElementById('configContent');
            if(toggleBtn) toggleBtn.onclick = () => {
                configContent.classList.toggle('hidden');
                toggleBtn.innerText = configContent.classList.contains('hidden') ? 'Settings' : 'Hide Settings';
            };
            
            ['speed', 'bulk', 'luck', 'target', 'customPercent', 'runeSearch'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.addEventListener('input', window.calculate);
            });
            
            ['speed2x', 'luck2x', 'bhSpeed', 'bhLuck'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.addEventListener('change', window.calculate);
            });
            
            document.getElementById('modeCategory').addEventListener('click', window.setModeCategory);
            document.getElementById('modeEta').addEventListener('click', window.setModeEta);
            
            window.calculate();
        });
    </script>
</body>
</html>
