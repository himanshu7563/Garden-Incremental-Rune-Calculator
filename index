        function renderRunes(totalPower) {
            const grid = document.getElementById('runesGrid');
            if(!grid) return;
            
            const searchInput = document.getElementById('runeSearch');
            const searchTerm = searchInput ? searchInput.value.toLowerCase() : '';
            
            let filtered = runeData.filter(rune => 
                rune.name.toLowerCase().includes(searchTerm) || 
                rune.type.toLowerCase().includes(searchTerm)
            );
            
            filtered.sort((a, b) => {
                const pinA = window.pinnedRunes.has(a.name) ? 1 : 0;
                const pinB = window.pinnedRunes.has(b.name) ? 1 : 0;
                if (pinA !== pinB) return pinB - pinA; 

                if (window.sortConfig.mode === 'category') {
                    const catA = categoryOrder.indexOf(a.type);
                    const catB = categoryOrder.indexOf(b.type);
                    if (catA !== catB) return catA - catB;
                    
                    return parseValue(a.raw) - parseValue(b.raw);
                } else {
                    const valA = parseValue(a.raw);
                    const valB = parseValue(b.raw);
                    return window.sortConfig.direction === 'asc' ? valA - valB : valB - valA;
                }
            });
            
            document.getElementById('modeCategory').innerText = `Total Rune: ${filtered.length}`;
